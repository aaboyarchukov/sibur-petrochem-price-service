# Скопируй в .env и задай пароль. docker-compose, Makefile и бэкенд (internal/config) читают эти значения.
PG_DB_USER=sibur
PG_DB_PASSWORD=change_me
PG_DB_NAME=sibur
PG_DB_HOST=localhost
PG_DB_PORT=5432
PG_DB_SSLMODE=disable

# Необязательно (есть значения по умолчанию в internal/config):
# PG_DB_MAX_CONNS=25
# PG_DB_MIN_CONNS=5
# SERVER_ADDR=:8080
# SERVER_READ_HEADER_TIMEOUT=5s
# SERVER_SHUTDOWN_TIMEOUT=10s

# Кнопка «Загрузить демо-набор» на экране источников (по умолчанию выключена)
DEMO_ENABLED=false
